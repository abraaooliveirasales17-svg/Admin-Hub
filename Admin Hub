-- Fechar menu ao clicar fora (2 cliques)
local clicksOutside = 0
local lastClickTime = 0

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not MenuOpen then return end
    if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end

    -- Verificar se o clique está fora do menu
    local mousePos = UserInputService:GetMouseLocation()
    local mainAbsPos = MainFrame.AbsolutePosition
    local mainAbsSize = MainFrame.AbsoluteSize

    local insideMenu = mousePos.X >= mainAbsPos.X and mousePos.X <= mainAbsPos.X + mainAbsSize.X and
                       mousePos.Y >= mainAbsPos.Y and mousePos.Y <= mainAbsPos.Y + mainAbsSize.Y

    if not insideMenu then
        local currentTime = tick()
        if currentTime - lastClickTime < 0.5 then
            clicksOutside = clicksOutside + 1
        else
            clicksOutside = 1
        end
        lastClickTime = currentTime

        if clicksOutside >= 2 then
            clicksOutside = 0
            -- Fechar menu
            local closeTween = TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                Size = UDim2.new(0, 0, 0, 0),
                BackgroundTransparency = 1
            })
            closeTween:Play()
            closeTween.Completed:Connect(function()
                MainFrame.Visible = false
                MainFrame.Size = UDim2.new(0, 520, 0, 370)
                MainFrame.BackgroundTransparency = 0
                IconButton.Visible = true
                MenuOpen = false
            end)
        end
    else
        clicksOutside = 0
    end
end)

