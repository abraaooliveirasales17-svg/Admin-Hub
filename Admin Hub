local function SelectTab(tabName)
    CurrentTab = tabName
    for name, data in pairs(TabButtons) do
        if name == tabName then
            TweenService:Create(data.Button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 50, 50)}):Play()
            data.Label.TextColor3 = Color3.fromRGB(255, 255, 255)
            data.Icon.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            TweenService:Create(data.Button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(25, 25, 25)}):Play()
            data.Label.TextColor3 = Color3.fromRGB(180, 180, 180)
            data.Icon.TextColor3 = Color3.fromRGB(200, 200, 200)
        end
    end
    for name, container in pairs(TabContents) do
        container.Visible = (name == tabName)
    end
end

