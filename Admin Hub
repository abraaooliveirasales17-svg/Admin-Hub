local function GetCharacter()
    return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

local function GetHumanoid()
    local char = GetCharacter()
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function GetRootPart()
    local char = GetCharacter()
    return char and char:FindFirstChild("HumanoidRootPart")
end

-- SPEED
local speedConnection = nil
local function SetSpeed(active, value)
    States.Speed.Active = active
    States.Speed.Value = tonumber(value) or 16
    if speedConnection then speedConnection:Disconnect(); speedConnection = nil end
    if active then
        speedConnection = RunService.Heartbeat:Connect(function()
            local hum = GetHumanoid()
            if hum then
                hum.WalkSpeed = States.Speed.Value
            end
        end)
    else
        local hum = GetHumanoid()
        if hum then hum.WalkSpeed = 16 end
    end
end

-- JUMP
local jumpConnection = nil
local function SetJump(active, value)
    States.Jump.Active = active
    States.Jump.Value = tonumber(value) or 50
    if jumpConnection then jumpConnection:Disconnect(); jumpConnection = nil end
    if active then
        jumpConnection = RunService.Heartbeat:Connect(function()
            local hum = GetHumanoid()
            if hum then
                hum.JumpPower = States.Jump.Value
                hum.UseJumpPower = true
            end
        end)
    else
        local hum = GetHumanoid()
        if hum then
            hum.JumpPower = 50
            hum.UseJumpPower = true
        end
    end
end

-- INFINITE JUMP
local function SetInfJump(active)
    States.InfJump.Active = active
    if InfJumpConnection then InfJumpConnection:Disconnect(); InfJumpConnection = nil end
    if active then
        InfJumpConnection = UserInputService.JumpRequest:Connect(function()
            local hum = GetHumanoid()
            if hum then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)
    end
end

-- NOCLIP
local function SetNoclip(active)
    States.Noclip.Active = active
    if NoclipConnection then NoclipConnection:Disconnect(); NoclipConnection = nil end
    if active then
        NoclipConnection = RunService.Stepped:Connect(function()
            local char = GetCharacter()
            if char then
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    else
        local char = GetCharacter()
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                    part.CanCollide = true
                end
            end
        end
    end
end

-- TELEPORT
local function TeleportToPlayer(targetName)
    local rootPart = GetRootPart()
    if not rootPart then return end

    for _, player in pairs(Players:GetPlayers()) do
        if string.lower(player.Name):find(string.lower(targetName)) or
           string.lower(player.DisplayName):find(string.lower(targetName)) then
            local targetChar = player.Character
            if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                rootPart.CFrame = targetChar.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                return true
            end
        end
    end
    return false
end

-- LOOP TELEPORT
local function SetLoopTP(active, targetName)
    States.LoopTP.Active = active
    States.LoopTP.Target = targetName
    if LoopTPConnection then LoopTPConnection:Disconnect(); LoopTPConnection = nil end
    if active and targetName ~= "" then
        LoopTPConnection = RunService.Heartbeat:Connect(function()
            TeleportToPlayer(targetName)
        end)
