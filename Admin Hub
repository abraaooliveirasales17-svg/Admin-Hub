end

-- ESP
local function CreateESP(player)
    if player == LocalPlayer then return end

    local function SetupESP(character)
        -- Limpa ESP antigo deste player
        if ESPObjects[player.Name] then
            for _, obj in pairs(ESPObjects[player.Name]) do
                if obj and obj.Parent then obj:Destroy() end
            end
        end
        ESPObjects[player.Name] = {}

        local hrp = character:WaitForChild("HumanoidRootPart", 5)
        local head = character:WaitForChild("Head", 5)
        if not hrp or not head then return end

        -- Highlight
        local highlight = Instance.new("Highlight")
        highlight.Name = "ESP_Highlight"
        highlight.Adornee = character
        highlight.FillTransparency = 0.7
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

        -- Cor do time
        local teamColor = Color3.fromRGB(255, 255, 255)
        if player.Team then
            teamColor = player.Team.TeamColor.Color
        end
        highlight.FillColor = teamColor
        highlight.OutlineColor = teamColor
        highlight.Parent = character

        -- BillboardGui com nome
        local billboard = Instance.new("BillboardGui")
        billboard.Name = "ESP_Name"
        billboard.Adornee = head
        billboard.Size = UDim2.new(0, 200, 0, 50)
        billboard.StudsOffset = Vector3.new(0, 2.5, 0)
        billboard.AlwaysOnTop = true
        billboard.Parent = character

        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = player.Name
        nameLabel.TextColor3 = teamColor
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextSize = 14
        nameLabel.TextStrokeTransparency = 0.5
        nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        nameLabel.Parent = billboard

        -- Distância
        local distLabel = Instance.new("TextLabel")
        distLabel.Size = UDim2.new(1, 0, 0.5, 0)
        distLabel.Position = UDim2.new(0, 0, 0.5, 0)
        distLabel.BackgroundTransparency = 1
        distLabel.Text = "0m"
        distLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
        distLabel.Font = Enum.Font.Gotham
        distLabel.TextSize = 11
        distLabel.TextStrokeTransparency = 0.5
        distLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        distLabel.Parent = billboard

        table.insert(ESPObjects[player.Name], highlight)
        table.insert(ESPObjects[player.Name], billboard)

        -- Atualizar distância
        local distConnection
        distConnection = RunService.Heartbeat:Connect(function()
            if not billboard.Parent or not States.ESP.Active then
                distConnection:Disconnect()
                return
            end
            local myRoot = GetRootPart()
            if myRoot and hrp and hrp.Parent then
                local dist = math.floor((myRoot.Position - hrp.Position).Magnitude)
                distLabel.Text = dist .. "m"
            end
        end)
        table.insert(ESPObjects[player.Name], {Destroy = function() distConnection:Disconnect() end})
    end

    if player.Character then
        SetupESP(player.Character)
    end
    player.CharacterAdded:Connect(function(char)
        if States.ESP.Active then
            task.wait(1)
            SetupESP(char)
        end
    end)
end

local function ClearAllESP()
    for playerName, objects in pairs(ESPObjects) do
        for _, obj in pairs(objects) do
            if obj and typeof(obj) == "Instance" and obj.Parent then
                obj:Destroy()
            elseif obj and type(obj) == "table" and obj.Destroy then
                obj:Destroy()
            end
        end
    end
    ESPObjects = {}
end

local function SetESP(active)
    States.ESP.Active = active
    if active then
        for _, player in pairs(Players:GetPlayers()) do
            CreateESP(player)
        end
        Players.PlayerAdded:Connect(function(player)
            if States.ESP.Active then
                player.CharacterAdded:Connect(function()
                    task.wait(1)
                    if States.ESP.Active then
                        CreateESP(player)
                    end
                end)
            end
        end)
    else
        ClearAllESP()
    end
end

-- FPS BOOST
local function FPSBoost()
    local terrain = workspace:FindFirstChildOfClass("Terrain")

    -- Configurações de iluminação
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Brightness = 1

    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)

    -- Remover efeitos de pós-processamento
    for _, effect in pairs(Lighting:GetChildren()) do
        if effect:IsA("PostEffect") or effect:IsA("BlurEffect") or effect:IsA("SunRaysEffect") or
           effect:IsA("ColorCorrectionEffect") or effect:IsA("BloomEffect") or effect:IsA("DepthOfFieldEffect") then
            effect:Destroy()
        end
    end

    -- Desativar decorações do terrain
    if terrain then
        terrain.WaterWaveSize = 0
        terrain.WaterWaveSpeed = 0
        terrain.WaterReflectance = 0
        terrain.WaterTransparency = 0
        pcall(function() terrain.Decoration = false end)
    end

    -- Simplificar materiais de partes
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            obj.Material = Enum.Material.SmoothPlastic
            obj.Reflectance = 0
        elseif obj:IsA("Decal") or obj:IsA("Texture") then
            obj.Transparency = 1
        elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Fire") or
               obj:IsA("Smoke") or obj:IsA("Sparkles") then
            obj.Enabled = false
        elseif obj:IsA("MeshPart") then
            obj.Material = Enum.Material.SmoothPlastic
            obj.Reflectance = 0
            pcall(function() obj.TextureID = "" end)
        end
    end
end

-- TP TOOL
local function CreateTPTool()
    -- Remover ferramentas antigas com mesmo nome
    local backpack = LocalPlayer:WaitForChild("Backpack")
    for _, tool in pairs(backpack:GetChildren()) do
        if tool.Name == "TP Tool" then tool:Destroy() end
    end
    local char = GetCharacter()
    if char then
        for _, tool in pairs(char:GetChildren()) do
            if tool.Name == "TP Tool" then tool:Destroy() end
        end
    end

    local tool = Instance.new("Tool")
    tool.Name = "TP Tool"
    tool.RequiresHandle = true
    tool.CanBeDropped = true

    local handle = Instance.new("Part")
    handle.Name = "Handle"
    handle.Size = Vector3.new(1, 1, 4)
    handle.BrickColor = BrickColor.new("Lime green")
    handle.Material = Enum.Material.Neon
    handle.CanCollide = false
    handle.Parent = tool

    local mesh = Instance.new("SpecialMesh")
    mesh.MeshType = Enum.MeshType.Cylinder
    mesh.Scale = Vector3.new(0.5, 0.5, 1)
    mesh.Parent = handle

    tool.Activated:Connect(function()
        local rootPart = GetRootPart()
        if rootPart and Mouse.Hit then
            rootPart.CFrame = Mouse.Hit + Vector3.new(0, 3, 0)
        end
    end)

    tool.Parent = backpack
end

